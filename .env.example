SECRET_KEY=change-me-to-a-random-secret-key
APP_PORT=8097
API_PUBLIC_URL=http://localhost:8097
ECOMMERCE_PUBLIC_URL=http://localhost:5174
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Orígenes permitidos (sin barra final). Incluir admin + tienda + Firebase + dev.
# Producción:
# CORS_ORIGINS=https://admin.binfrix.io,https://tienda.binfrix.io,https://api.binfrix.io,https://binfrix-ecommerce.firebaseapp.com,https://binfrix-ecommerce.web.app
# Desarrollo local:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5176,http://127.0.0.1:5176,https://admin.binfrix.io,https://tienda.binfrix.io,https://api.binfrix.io,https://binfrix-ecommerce.firebaseapp.com,https://binfrix-ecommerce.web.app

# MySQL (opción A: variables separadas)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=binfrix
MYSQL_PASSWORD=tu_password
MYSQL_DATABASE=binfrix
# Producción (socket local, cPanel/VPS): descomenta si TCP falla con 127.0.0.1
# MYSQL_UNIX_SOCKET=/var/run/mysqld/mysqld.sock

# MySQL (opción B: URL completa — tiene prioridad si se define)
# DATABASE_URL=mysql+pymysql://binfrix:tu_password@127.0.0.1:3307/binfrix?charset=utf8mb4
