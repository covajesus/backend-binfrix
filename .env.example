# Orígenes permitidos (sin barra final). Incluir admin + tienda + dev.
# Producción:
# CORS_ORIGINS=https://admin.binfrix.io,https://tienda.binfrix.io
# Desarrollo local:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5176,http://127.0.0.1:5176,https://admin.binfrix.io,https://tienda.binfrix.io,https://api.binfrix.io

# MySQL (opción A: variables separadas)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=binfrix
MYSQL_PASSWORD=tu_password
MYSQL_DATABASE=binfrix

