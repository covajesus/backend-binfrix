# Copiar a /etc/systemd/system/binfrix-api.service y ajustar rutas si hace falta.
# sudo systemctl daemon-reload && sudo systemctl enable --now binfrix-api

[Unit]
Description=Binfrix API (FastAPI / uvicorn)
After=network.target mysql.service

[Service]
User=intrajis
Group=www-data
WorkingDirectory=/var/www/api.binfrix.io/public_html
Environment=PATH=/var/www/api.binfrix.io/public_html/venv/bin
ExecStart=/var/www/api.binfrix.io/public_html/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8097
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
